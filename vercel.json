{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "api/handler.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/user/(.*)", "dest": "/api/handler.php" },
    { "src": "/farmer/(.*)", "dest": "/api/handler.php" },
    { "src": "/officers/(.*)", "dest": "/api/handler.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
